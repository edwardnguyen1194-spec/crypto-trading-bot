# ═══════════════════════════════════════════════════
#  Bitunix Crypto Trading Agent Configuration
# ═══════════════════════════════════════════════════

# API Credentials (REQUIRED - get from Bitunix dashboard)
BITUNIX_API_KEY=your_api_key_here
BITUNIX_SECRET_KEY=your_secret_key_here

# ─── Trading Mode ───
DRY_RUN=true                  # true = paper trading, false = REAL money

# ─── Capital ───
BANKROLL=200                  # Starting capital in USDT

# ─── Symbols ───
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# ─── Leverage ───
MAX_LEVERAGE=20               # VIP1 max leverage
DEFAULT_LEVERAGE=10           # Default leverage per trade

# ─── Risk Management ───
MAX_RISK_PER_TRADE=0.02       # 2% of bankroll per trade
MAX_DAILY_LOSS=0.10           # 10% daily loss limit - stops all trading

# ─── Scanning ───
SCAN_INTERVAL=30000           # Scan every 30 seconds (in ms)

# ─── Strategy Tuning ───
MIN_CONFLUENCE=3              # Minimum strategies agreeing (out of 5)
MIN_SCORE=35                  # Minimum composite score to trade (0-100)
